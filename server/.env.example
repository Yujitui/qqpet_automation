# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qqpet

# JWT 配置（生产环境请修改为随机字符串）
JWT_SECRET_KEY=your-secret-key-change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
